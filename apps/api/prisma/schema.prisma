  totalMins    Float    @default(0)
  songsPlayed  Int      @default(0)
  topGenre     String?
  topArtistId  String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, recordedDate])
  @@index([recordedDate])
  @@index([userId])
  @@map("daily_listening_stats")
}

model WeeklyListeningStats {
  id          String   @id @default(uuid())
  userId      String
  weekStart   DateTime @db.Date
  totalMins   Float    @default(0)
  songsPlayed Int      @default(0)
  topGenre    String?
  topArtistId String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([weekStart])
  @@map("weekly_listening_stats")
}

model MonthlyListeningStats {
  id          String   @id @default(uuid())
  userId      String
  monthStart  DateTime @db.Date
  totalMins   Float    @default(0)
  songsPlayed Int      @default(0)
  topGenre    String?
  topArtistId String?
