model UserDevice {
  id          String   @id @default(uuid())
  userId      String
  deviceName  String?
  deviceType  String?
  platform    String?
  osVersion   String?
  appVersion  String?
  fingerprint String?  @unique
  lastSeenAt  DateTime @default(now())
