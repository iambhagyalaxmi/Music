  repeatMode           String   @default("OFF") // OFF, ALL, ONE
  shuffleMode          Boolean  @default(false)
  defaultVolume        Int      @default(80)
  videoAutoPlay        Boolean  @default(true)
  lyricsDisplay        Boolean  @default(true)
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("playback_settings")
}

model AudioSettings {
