  streamingQuality String   @default("HIGH") // LOW, MEDIUM, HIGH, LOSSLESS
  downloadQuality  String   @default("HIGH")
  equalizerPreset  String   @default("NORMAL")
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audio_settings")
}

model VoiceSettings {
  userId              String   @id
  microphoneId        String?
  speakerId           String?
  noiseCancellation   Boolean  @default(true)
  echoCancellation    Boolean  @default(true)
  pushToTalk          Boolean  @default(false)
  autoGainControl     Boolean  @default(true)
  voiceActivityDetect Boolean  @default(true)
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("voice_settings")
}

model ChatSettings {
  userId            String   @id
  readReceipts      Boolean  @default(true)
  typingIndicator   Boolean  @default(true)
  messagePreview    Boolean  @default(true)
  autoDownloadMedia Boolean  @default(true)
  chatBackground    String?
  emojiSuggestions  Boolean  @default(true)
  gifSupport        Boolean  @default(true)
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chat_settings")
}

model ThemeSettings {
  userId           String   @id
  themeMode        String   @default("SYSTEM") // LIGHT, DARK, SYSTEM
  accentColor      String   @default("#1DB954")
  fontSize         String   @default("MEDIUM") // SMALL, MEDIUM, LARGE
  compactMode      Boolean  @default(false)
  sidebarPosition  String   @default("LEFT") // LEFT, RIGHT
  enableAnimations Boolean  @default(true)
  reduceMotion     Boolean  @default(false)
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("theme_settings")
}

model LanguageSettings {
  userId          String   @id
  language        String   @default("en-US")
  country         String   @default("US")
  timeZone        String   @default("UTC")
  dateFormat      String   @default("MM/DD/YYYY")
  timeFormat      String   @default("12H") // 12H, 24H
  regionalContent Boolean  @default(true)
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("language_settings")
}

// ============================================================
// MODULE 18: COMMUNITY
// ============================================================

model CommunityPost {
  id               String    @id @default(uuid())
  userId           String
  fanClubId        String?
  parentId         String?
  sharedSongId     String?
  sharedPlaylistId String?
  content          String
  tags             String[]
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions      CommunityPostReaction[]
  parent         CommunityPost?          @relation("PostComments", fields: [parentId], references: [id], onDelete: Cascade)
  comments       CommunityPost[]         @relation("PostComments")
  fanClub        FanClub?                @relation(fields: [fanClubId], references: [id], onDelete: Cascade)
  sharedSong     Song?                   @relation(fields: [sharedSongId], references: [id], onDelete: SetNull)
  sharedPlaylist Playlist?               @relation(fields: [sharedPlaylistId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([fanClubId])
  @@index([parentId])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("community_posts")
}

model CommunityPostReaction {
  id        String        @id @default(uuid())
  postId    String
  userId    String
  emoji     ReactionEmoji
  createdAt DateTime      @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId, emoji])
  @@map("community_post_reactions")
}

model FanClub {
  id          String    @id @default(uuid())
  name        String
  description String?
  ownerId     String
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner   User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members FanClubMember[]
  posts   CommunityPost[]

  @@index([ownerId])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("fan_clubs")
}

model FanClubMember {
  fanClubId String
  userId    String
  joinedAt  DateTime @default(now())

  fanClub FanClub @relation(fields: [fanClubId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([fanClubId, userId])
  @@index([userId])
  @@index([fanClubId])
  @@map("fan_club_members")
}

model CommunityPoll {
  id        String    @id @default(uuid())
  question  String
  creatorId String
  expiresAt DateTime?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  creator   User                    @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  options   CommunityPollOption[]
  reactions CommunityPollReaction[]

  @@index([creatorId])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("community_polls")
}

model CommunityPollOption {
  id     String @id @default(uuid())
  pollId String
  text   String

  poll  CommunityPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes CommunityPollVote[]

  @@index([pollId])
  @@map("community_poll_options")
}

model CommunityPollVote {
  id        String   @id @default(uuid())
  optionId  String
  userId    String
  createdAt DateTime @default(now())

  option CommunityPollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([optionId, userId])
  @@index([optionId])
  @@index([userId])
  @@map("community_poll_votes")
}

model CommunityPollReaction {
  id        String        @id @default(uuid())
  pollId    String
  userId    String
  emoji     ReactionEmoji
  createdAt DateTime      @default(now())

  poll CommunityPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([pollId, emoji])
  @@map("community_poll_reactions")
}
