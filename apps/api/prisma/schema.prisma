  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, monthStart])
  @@index([monthStart])
  @@map("monthly_listening_stats")
}

model TopArtist {
  id         String   @id @default(uuid())
  artistId   String
  period     String
  rank       Int
  playCount  BigInt
  recordedAt DateTime @default(now())

