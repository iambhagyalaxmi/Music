  @@index([recordedAt])
  @@map("top_artists")
}

model TopSong {
  id         String   @id @default(uuid())
  songId     String
  period     String
  rank       Int
  playCount  BigInt
  recordedAt DateTime @default(now())

  @@index([period, rank])
  @@index([recordedAt])
  @@map("top_songs")
